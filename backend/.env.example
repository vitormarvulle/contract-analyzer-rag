# Contract Analyzer — Backend Environment Variables
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults and the app will run without a .env file.

# ── Ollama / LLM ─────────────────────────────────────────────────────────────
# Base URL for the Ollama OpenAI-compatible API endpoint.
OLLAMA_BASE_URL=http://localhost:11434/v1

# Ollama requires a non-empty api_key even though it performs no authentication.
OLLAMA_API_KEY=ollama

# The Ollama model to use for chat completions.
# Other options: mistral, gemma3, deepseek-r1, phi3
OLLAMA_MODEL=llama3.1:8b

# ── Embeddings ───────────────────────────────────────────────────────────────
# HuggingFace model identifier for sentence-transformers.
# Downloaded automatically on first run (~2.3 GB, cached at ~/.cache/huggingface/).
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# Device for embedding inference. Use "cuda" for NVIDIA GPU, "mps" for Apple Silicon.
EMBEDDING_DEVICE=cpu

# ── ChromaDB ─────────────────────────────────────────────────────────────────
# Directory where ChromaDB persists vector data.
CHROMA_PERSIST_DIR=./chroma_db

# ── Chunking ─────────────────────────────────────────────────────────────────
# Target chunk size in characters.
CHUNK_SIZE=1000

# Overlap between consecutive chunks in characters.
CHUNK_OVERLAP=150

# ── Retrieval ─────────────────────────────────────────────────────────────────
# Number of top chunks to retrieve per query.
TOP_K_RESULTS=5

# ── Logging ──────────────────────────────────────────────────────────────────
# Python logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
